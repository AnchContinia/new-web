{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "assets/**",
              "components/brand/**",
              "components/buttons/**",
              "components/data-display/**",
              "components/forms/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Alliance No\\.2))/i]",
        "message": "Font not provided by the design system. Available: Alliance No.2."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|caps|block|icon|iconRight|href|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, caps, block, icon, iconRight, href, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|purple|innovation|white|ghost-dark)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'purple' | 'innovation' | 'white' | 'ghost-dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|hover|icon|eyebrow|title|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: variant, hover, icon, eyebrow, title, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|flat|tint|brand)$/]",
        "message": "<Card> variant must be one of 'default' | 'flat' | 'tint' | 'brand'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|type|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: label, type."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:checkbox|radio)$/]",
        "message": "<Checkbox> type must be one of 'checkbox' | 'radio'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|icon|required|invalid|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, icon, required, invalid."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute > JSXIdentifier[name!=/^(?:color|markOnly|height|key|ref|className|style|children)$/]",
        "message": "<Logo> doesn't accept that prop. Declared props: color, markOnly, height."
      },
      {
        "selector": "JSXOpeningElement[name.name='PopupWindow'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|variant|children|key|ref|className|style|children)$/]",
        "message": "<PopupWindow> doesn't accept that prop. Declared props: title, variant, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='PopupWindow'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|innovation)$/]",
        "message": "<PopupWindow> variant must be one of 'default' | 'innovation'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatPanel'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|variant|icon|key|ref|className|style|children)$/]",
        "message": "<StatPanel> doesn't accept that prop. Declared props: value, label, variant, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatPanel'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|light|green|purple)$/]",
        "message": "<StatPanel> variant must be one of 'default' | 'light' | 'green' | 'purple'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|wide|children|key|ref|className|style|children)$/]",
        "message": "<StatusChip> doesn't accept that prop. Declared props: status, wide, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusChip'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:neutral|info|warning|success)$/]",
        "message": "<StatusChip> status must be one of 'neutral' | 'info' | 'warning' | 'success'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|dot|children|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: variant, dot, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:neutral|brand|solid|innovation|success|warning|feature)$/]",
        "message": "<Tag> variant must be one of 'neutral' | 'brand' | 'solid' | 'innovation' | 'success' | 'warning' | 'feature'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
